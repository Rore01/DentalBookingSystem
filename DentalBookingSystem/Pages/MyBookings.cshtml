@page
@model DentalBookingSystem.Pages.MyBookingsModel
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@{
    ViewData["Title"] = "My Bookings";
    ViewData["ActivePage"] = "";
    Layout = "_Layout";

    var userName = User.Identity?.Name ?? "Patient";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";

    var upcoming = Model.Bookings.Where(b => b.Status == "Confirmed" && b.Date >= DateOnly.FromDateTime(DateTime.Today)).OrderBy(b => b.Date).ToList();
    var past = Model.Bookings.Where(b => b.Status == "Completed" || b.Date < DateOnly.FromDateTime(DateTime.Today)).OrderByDescending(b => b.Date).ToList();
    var cancelled = Model.Bookings.Where(b => b.Status == "Cancelled").OrderByDescending(b => b.Date).ToList();

    var tomorrow = DateOnly.FromDateTime(DateTime.Today.AddDays(1));
    var tomorrowBooking = upcoming.FirstOrDefault(b => b.Date == tomorrow);
}

<style>
    body { background: #f0f4f7; }
    .dashboard-wrapper { display: grid; grid-template-columns: 240px 1fr; min-height: calc(100vh - 64px); }
    .section-heading { font-size: 13px; font-weight: 600; color: var(--muted); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 12px; margin-top: 24px; }
    .booking-new-card { display: flex; align-items: center; justify-content: center; background: var(--mint); border-radius: 14px; border: 2px dashed #aad9cf; cursor: pointer; min-height: 130px; text-decoration: none; transition: all .2s; }
    .booking-new-card:hover { border-color: var(--teal); background: #d5ede6; }
    .booking-new-inner { text-align: center; color: var(--teal); }
    .booking-new-inner .plus { font-size: 28px; margin-bottom: 8px; }
    .booking-new-inner span { font-size: 13px; font-weight: 600; display: block; }
    .booking-price { font-size: 13px; color: var(--teal); font-weight: 600; margin-bottom: 12px; }
    .booking-price.muted { color: var(--muted); }
    .empty-state { text-align: center; padding: 40px; color: var(--muted); font-size: 14px; }
</style>

<div class="dashboard-wrapper">

    <!-- ── SIDEBAR ── -->
    <div class="cust-sidebar">
        <div class="cust-avatar">👤</div>
        <div class="cust-name">@userName</div>
        <div class="cust-email">@userEmail</div>
        <nav class="cust-nav">
            <a asp-page="/MyBookings" class="active"><span>📅</span> My Bookings</a>
            <a asp-page="/Book"><span>➕</span> Book New</a>
            <a asp-page="/Account"><span>⚙️</span> Account</a>
            <form asp-page="/Account/Logout" method="post">
                <button type="submit" style="background:none;border:none;width:100%;text-align:left;cursor:pointer;">
                    <a style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;color:rgba(255,255,255,0.65);font-size:13px;font-weight:500;text-decoration:none;">
                        <span>🚪</span> Log out
                    </a>
                </button>
            </form>
        </nav>
    </div>

    <!-- ── MAIN ── -->
    <div class="cust-main">
        @if (TempData["Success"] != null)
        {
            <div style="background:#e8f8f2;border:1px solid #a0dfc5;color:#1a7a6e;padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:20px;">
                ✅ @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div style="background:#fde8e8;border:1px solid #f5b8b8;color:#c0392b;padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:20px;">
                ❌ @TempData["Error"]
            </div>
        }
        <div class="cust-header">
            <h2>My Appointments</h2>
            <p>Manage and track your upcoming and past dental visits</p>
        </div>

        @* Tomorrow reminder banner *@
        @if (tomorrowBooking != null)
        {
            <div class="reminder-banner">
                <div class="reminder-icon">🔔</div>
                <div class="reminder-text">
                    <h4>Reminder: Appointment Tomorrow!</h4>
                    <p>@tomorrowBooking.TreatmentName · @tomorrowBooking.StartTime.ToString("HH:mm") · DentaCare Clinic</p>
                </div>
                <a class="reminder-cta">View Details</a>
            </div>
        }

        @* Upcoming bookings *@
        <div class="section-heading">Upcoming</div>
        <div class="booking-cards">
            @if (upcoming.Any())
            {
                @foreach (var booking in upcoming)
                {
                    <div class="booking-card upcoming">
                        <div class="booking-date">@booking.Date.ToString("MMMM d").ToUpper()</div>
                        <div class="booking-treatment">@booking.TreatmentName</div>
                        <div class="booking-time">⏰ @booking.StartTime.ToString("HH:mm") – @booking.EndTime.ToString("HH:mm") · @booking.DurationMinutes min</div>
                        <div class="booking-price">@booking.Price.ToString("N0") kr</div>
                        <div class="booking-actions">
                            <a asp-page="/Book" asp-route-rescheduleId="@booking.Id" class="btn-tiny reschedule">🔄 Reschedule</a>
                            <form method="post" asp-page-handler="Cancel" style="display:inline">
                                <input type="hidden" name="bookingId" value="@booking.Id" />
                                <button type="submit" class="btn-tiny cancel"
                                    onclick="return confirm('Cancel this appointment?')">✕ Cancel</button>
                            </form>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state" style="grid-column:1/3;">No upcoming appointments.</div>
            }

            @* Book new card *@
            <a asp-page="/Book" class="booking-new-card">
                <div class="booking-new-inner">
                    <div class="plus">+</div>
                    <span>Book New Appointment</span>
                </div>
            </a>
        </div>

        @* Past visits *@
        @if (past.Any() || cancelled.Any())
        {
            <div class="section-heading">Past Visits</div>
            <div class="booking-cards">
                @foreach (var booking in past)
                {
                    <div class="booking-card past">
                        <div class="booking-date">@booking.Date.ToString("MMMM d").ToUpper()</div>
                        <div class="booking-treatment">@booking.TreatmentName</div>
                        <div class="booking-time">⏰ @booking.StartTime.ToString("HH:mm") – @booking.EndTime.ToString("HH:mm") · @booking.DurationMinutes min</div>
                        <div class="booking-price muted">@booking.Price.ToString("N0") kr</div>
                    </div>
                }
                @foreach (var booking in cancelled)
                {
                    <div class="booking-card cancelled-card">
                        <div class="booking-date">@booking.Date.ToString("MMMM d").ToUpper()</div>
                        <div class="booking-treatment">@booking.TreatmentName</div>
                        <div class="booking-time">⏰ @booking.StartTime.ToString("HH:mm") – @booking.EndTime.ToString("HH:mm") · @booking.DurationMinutes min</div>
                        <div style="font-size:13px;color:var(--red);font-weight:600;margin-bottom:12px;">Cancelled</div>
                    </div>
                }
            </div>
        }
    </div>
</div>
