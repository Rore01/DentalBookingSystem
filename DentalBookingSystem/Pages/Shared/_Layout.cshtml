<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DentaCare</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🦷</text></svg>" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dental.css" asp-append-version="true" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<nav class="main-nav">
    <a class="logo" asp-page="/Index">Denta<span>Care</span></a>
        <div class="nav-links">
            <a asp-page="/Index" class="@(ViewData["ActivePage"]?.ToString() == "Home" ? "active" : "")">Home</a>
            @if (User.FindFirst("Role")?.Value == "Admin")
            {
                <a asp-page="/Admin/Dashboard">Dashboard</a>
                <a asp-page="/Book" class="@(ViewData["ActivePage"]?.ToString() == "Book" ? "active" : "")">Book Appointment</a>
            }
            else
            {
                <a asp-page="/MyBookings" class="@(ViewData["ActivePage"]?.ToString() == "MyBookings" ? "active" : "")">My Bookings</a>
                <a asp-page="/Book" class="@(ViewData["ActivePage"]?.ToString() == "Book" ? "active" : "")">Book Appointment</a>
            }
        </div>
        <div class="nav-right">
            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (User.FindFirst("Role")?.Value != "Admin")
                {
                    <a asp-page="/Account" class="nav-login">Account</a>
                }
                <form asp-page="/Account/Logout" method="post" style="display:inline">
                    <button type="submit" class="btn-sm">Log out</button>
                </form>
            }
            else
            {
                <a asp-page="/Account/Login" class="nav-login">Log in</a>
                <a asp-page="/Book" class="btn-sm">Book Now →</a>
            }
        </div>
</nav>

    @RenderBody()

    @if (User.FindFirst("Role")?.Value != "Admin")
    {
        <footer class="site-footer">
            <div class="footer-inner">
                <div class="footer-brand">
                    <div class="footer-logo">Denta<span>Care</span></div>
                    <p>Your trusted dental clinic online. Book, manage and reschedule your appointments — anytime, anywhere.</p>
                    <div class="footer-social">
                        <a href="#" aria-label="Facebook">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" /></svg>
                        </a>
                        <a href="#" aria-label="Instagram">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" /><circle cx="12" cy="12" r="4" /><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" /></svg>
                        </a>
                        <a href="#" aria-label="Twitter/X">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" /></svg>
                        </a>
                    </div>
                </div>

                <div class="footer-col">
                    <h4>Quick Links</h4>
                    <a asp-page="/Index">Home</a>
                    <a asp-page="/Services">Services</a>
                    <a asp-page="/Book">Book Appointment</a>
                    <a asp-page="/MyBookings">My Bookings</a>
                </div>

                <div class="footer-col">
                    <h4>Contact</h4>
                    <p>📍 Tandläkarvägen 12, Stockholm</p>
                    <p>📞 <a href="tel:+46700000000">+46 70 000 00 00</a></p>
                    <p>✉️ <a href="mailto:clinic@dentacare.se">clinic@dentacare.se</a></p>
                    <p>🕐 Mon–Fri: 08:00 – 17:00</p>
                </div>
            </div>

            <div class="footer-bottom">
                <p>© @DateTime.Now.Year DentaCare. All rights reserved.</p>
            </div>
        </footer>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
