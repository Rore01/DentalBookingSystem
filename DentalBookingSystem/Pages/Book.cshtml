@page
@model DentalBookingSystem.Pages.BookModel
@{
    ViewData["Title"] = "Book Appointment";
    Layout = "_Layout";
}

<style>
    body { background: var(--cream); }

    .booking-page { max-width: 1200px; margin: 0 auto; padding: 40px 24px; }
    .booking-page h2 { font-family: 'Playfair Display', serif; font-size: 28px; color: var(--dark); margin-bottom: 8px; }
    .booking-page .subtitle { color: var(--muted); font-size: 14px; margin-bottom: 32px; }
    .booking-layout { display: grid; grid-template-columns: 260px 1fr 280px; gap: 24px; align-items: start; }

    .booking-sidebar { background: var(--dark); border-radius: 16px; padding: 24px; }
    .booking-sidebar h3 { color: white; font-size: 15px; font-weight: 600; margin-bottom: 16px; font-family: 'DM Sans', sans-serif; }
    .treatment-option { padding: 12px 14px; border-radius: 10px; cursor: pointer; margin-bottom: 8px; border: 1.5px solid transparent; position: relative; transition: all .15s; }
    .treatment-option:hover { background: rgba(255,255,255,0.07); }
    .treatment-option.selected { background: rgba(42,168,150,0.2); border-color: #2aa896; }
    .treatment-option .t-name { color: white; font-size: 14px; font-weight: 500; }
    .treatment-option .t-meta { display: flex; gap: 10px; margin-top: 3px; }
    .treatment-option .t-meta span { color: rgba(255,255,255,0.5); font-size: 12px; }
    .selected-check { position: absolute; top: 10px; right: 12px; color: #2aa896; font-weight: 700; font-size: 13px; }
    .selected-summary { margin-top: 24px; padding: 14px; background: rgba(42,168,150,0.15); border-radius: 10px; }
    .selected-summary .s-label { color: rgba(255,255,255,0.5); font-size: 11px; letter-spacing: 1px; margin-bottom: 6px; }
    .selected-summary .s-name { color: white; font-weight: 600; font-size: 14px; }
    .selected-summary .s-meta { color: rgba(255,255,255,0.6); font-size: 12px; margin-top: 4px; }

    .booking-calendar { background: white; border-radius: 16px; padding: 28px; border: 1px solid #e8edf0; }
    .cal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .cal-header h3 { font-size: 16px; font-weight: 600; color: var(--dark); font-family: 'DM Sans', sans-serif; }
    .cal-nav { display: flex; gap: 8px; }
    .cal-nav button { width: 32px; height: 32px; border-radius: 8px; border: 1px solid #dde4e8; background: white; cursor: pointer; font-size: 16px; color: #2c4a52; }
    .cal-nav button:hover { background: #e8f5f0; }
    .weekdays { display: grid; grid-template-columns: repeat(7,1fr); text-align: center; margin-bottom: 8px; }
    .weekday { font-size: 12px; font-weight: 600; color: #8a9aa5; padding: 4px 0; }
    .cal-grid { display: grid; grid-template-columns: repeat(7,1fr); gap: 4px; }
    .cal-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 13px; font-weight: 500; }
    .cal-day.has-slots { cursor: pointer; color: #1a7a6e; background: #e8f5f0; font-weight: 600; }
    .cal-day.has-slots:hover { background: #1a7a6e; color: white; }
    .cal-day.selected { background: #1a7a6e !important; color: white !important; font-weight: 700; }
    .cal-day.today { outline: 2px solid #2aa896; outline-offset: -2px; }
    .cal-day.blocked { color: #d0d8dd; }
    .cal-day.weekend { color: rgba(224,90,90,0.45); }
    .cal-legend { display: flex; gap: 18px; margin-top: 16px; flex-wrap: wrap; }
    .cal-legend span { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #8a9aa5; }
    .leg-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }

    .time-slots-panel { background: white; border-radius: 16px; padding: 24px; border: 1px solid #e8edf0; }
    .time-slots-panel h4 { font-size: 14px; font-weight: 600; color: var(--dark); margin-bottom: 16px; font-family: 'DM Sans', sans-serif; }
    .time-section h5 { font-size: 11px; font-weight: 600; color: #8a9aa5; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
    .time-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; }
    .time-slot { padding: 10px; border-radius: 8px; border: 1.5px solid #e8edf0; text-align: center; font-size: 13px; font-weight: 600; cursor: pointer; color: #0f2027; background: white; transition: all .15s; }
    .time-slot:hover { border-color: #2aa896; color: #1a7a6e; background: #e8f5f0; }
    .time-slot.selected { background: #1a7a6e; color: white; border-color: #1a7a6e; }
    .time-slot.unavailable { color: #c0c8d0; border-color: #f0f4f7; background: #f8fafb; cursor: not-allowed; pointer-events: none; }
    .hint { text-align: center; color: #8a9aa5; font-size: 13px; padding: 28px 0; }

    .bsummary { background: #f8fffe; border: 1px solid #d0ede8; border-radius: 10px; padding: 14px; margin-top: 8px; }
    .bsummary .bs-label { font-size: 12px; color: #8a9aa5; margin-bottom: 4px; }
    .bsummary .bs-treatment { font-weight: 600; font-size: 14px; }
    .bsummary .bs-time { font-size: 13px; color: #8a9aa5; }
    .bsummary .bs-price { font-size: 15px; font-weight: 700; color: #1a7a6e; margin-top: 6px; }
    .confirm-btn { width: 100%; margin-top: 14px; background: #1a7a6e; color: white; border: none; padding: 13px; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .confirm-btn:hover:not(:disabled) { background: #0f2027; }
    .confirm-btn:disabled { background: #c0c8d0; cursor: not-allowed; }

    .spinner { display: inline-block; width: 13px; height: 13px; border: 2px solid rgba(255,255,255,0.4); border-top-color: white; border-radius: 50%; animation: spin .6s linear infinite; vertical-align: middle; margin-right: 6px; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .alert { padding: 12px 16px; border-radius: 10px; font-size: 13px; margin-bottom: 20px; }
    .alert-success { background: #e8f8f2; border: 1px solid #a0dfc5; color: #1a7a6e; }
    .alert-error { background: #fde8e8; border: 1px solid #f5b8b8; color: #c0392b; }
    .login-prompt { background: #fff8f0; border: 1px solid #f5d9b0; border-radius: 10px; padding: 16px; text-align: center; font-size: 13px; color: #8a6030; margin-top: 12px; }
    .login-prompt a { color: #1a7a6e; font-weight: 600; }

    @@media (max-width: 900px) { .booking-layout { grid-template-columns: 1fr; } }
</style>

<div class="booking-page">
    <h2>Book an Appointment</h2>
    <p class="subtitle">Choose your treatment, pick a date and time, and confirm your booking.</p>

    <div id="alert-area"></div>

    <div class="booking-layout">

        <!-- ── TREATMENTS ── -->
        <div class="booking-sidebar">
            <h3>Select Treatment</h3>
            <div id="treatment-list">
                <div style="color:rgba(255,255,255,0.4);font-size:13px;">Loading…</div>
            </div>
            <div class="selected-summary" id="selected-summary" style="display:none;">
                <div class="s-label">SELECTED</div>
                <div class="s-name" id="sum-name"></div>
                <div class="s-meta" id="sum-meta"></div>
            </div>
        </div>

        <!-- ── CALENDAR ── -->
        <div class="booking-calendar">
            <div class="cal-header">
                <h3 id="cal-title">Select a treatment first</h3>
                <div class="cal-nav">
                    <button onclick="changeMonth(-1)">‹</button>
                    <button onclick="changeMonth(1)">›</button>
                </div>
            </div>
            <div class="weekdays">
                <div class="weekday">Mon</div><div class="weekday">Tue</div><div class="weekday">Wed</div>
                <div class="weekday">Thu</div><div class="weekday">Fri</div>
                <div class="weekday" style="color:#e05a5a;">Sat</div>
                <div class="weekday" style="color:#e05a5a;">Sun</div>
            </div>
            <div class="cal-grid" id="cal-grid"></div>
            <div class="cal-legend">
                <span><span class="leg-dot" style="background:#2aa896;"></span>Available</span>
                <span><span class="leg-dot" style="background:#e0e0e0;"></span>No slots</span>
                <span><span class="leg-dot" style="background:rgba(224,90,90,0.4);"></span>Weekend</span>
            </div>
        </div>

        <!-- ── TIME SLOTS ── -->
        <div class="time-slots-panel">
            <h4 id="slots-title">📅 Select a date</h4>
            <div id="slots-area">
                <div class="hint">← Pick a date to see available times</div>
            </div>
            <div id="booking-summary" style="display:none;">
                <div class="bsummary">
                    <div class="bs-label">BOOKING SUMMARY</div>
                    <div class="bs-treatment" id="bs-treatment"></div>
                    <div class="bs-time" id="bs-time"></div>
                    <div class="bs-price" id="bs-price"></div>
                </div>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="confirm-btn" id="confirm-btn" onclick="confirmBooking()">
                        @(Model.RescheduleId.HasValue ? "Confirm Reschedule →" : "Confirm Booking →")
                    </button>
                }
                else
                {
                    <div class="login-prompt">
                        Please <a href="/Account/Login?returnUrl=/Book">log in</a> or
                        <a href="/Account/Register">register</a> to confirm your booking.
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    const CLINIC_ID = @Model.ClinicId;
    const PATIENT_ID = @(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
    const RESCHEDULE_ID = @(Model.RescheduleId?.ToString() ?? "null");
    const MONTH_NAMES = ['January','February','March','April','May','June',
                         'July','August','September','October','November','December'];

    let selectedTreatment = null;
    let selectedDate = null;
    let selectedTime = null;
    let curYear = new Date().getFullYear();
    let curMonth = new Date().getMonth() + 1;
    let availableDates = new Set();

    // ── TREATMENTS ────────────────────────────────────────
    async function loadTreatments() {
        try {
            const res = await fetch(`http://localhost:5296/api/treatments?clinicId=${CLINIC_ID}`);
            const list = await res.json();
            document.getElementById('treatment-list').innerHTML = list.map(t => `
                <div class="treatment-option" data-id="${t.id}" onclick="selectTreatment(${t.id},'${escHtml(t.name)}',${t.price},${t.durationMinutes})">
                    <div class="t-name">${escHtml(t.name)}</div>
                    <div class="t-meta"><span>${t.price.toLocaleString('sv-SE')} kr</span><span>${t.durationMinutes} min</span></div>
                </div>`).join('');
        } catch {
            document.getElementById('treatment-list').innerHTML =
                '<div style="color:rgba(255,255,255,0.4);font-size:13px;">Could not load treatments.</div>';
        }
    }

    function selectTreatment(id, name, price, duration) {
        selectedTreatment = { id, name, price, duration };
        selectedDate = null; selectedTime = null;

        document.querySelectorAll('.treatment-option').forEach(el => {
            el.classList.remove('selected');
            el.querySelector('.selected-check')?.remove();
        });
        const el = document.querySelector(`[data-id="${id}"]`);
        if (el) { el.classList.add('selected'); el.insertAdjacentHTML('beforeend','<span class="selected-check">✓</span>'); }

        document.getElementById('selected-summary').style.display = 'block';
        document.getElementById('sum-name').textContent = name;
        document.getElementById('sum-meta').textContent = `${duration} min · ${price.toLocaleString('sv-SE')} kr`;

        clearSlots(); hideBookingSummary();
        loadAvailableDates();
    }

    // ── CALENDAR ──────────────────────────────────────────
    function changeMonth(d) {
        curMonth += d;
        if (curMonth > 12) { curMonth = 1; curYear++; }
        if (curMonth < 1)  { curMonth = 12; curYear--; }
        selectedDate = null; selectedTime = null;
        clearSlots(); hideBookingSummary();
        if (selectedTreatment) loadAvailableDates();
        else renderCalendar(new Set());
    }

    async function loadAvailableDates() {
        document.getElementById('cal-title').textContent = 'Loading…';
        try {
            const res = await fetch(`http://localhost:5296/api/availability/dates?clinicId=${CLINIC_ID}&treatmentId=${selectedTreatment.id}&year=${curYear}&month=${curMonth}`);
            const data = await res.json();
            availableDates = new Set(data.availableDates ?? data);
        } catch { availableDates = new Set(); }
        renderCalendar(availableDates);
    }

    function renderCalendar(available) {
        document.getElementById('cal-title').textContent = `${MONTH_NAMES[curMonth-1]} ${curYear}`;
        const firstDay = new Date(curYear, curMonth - 1, 1);
        const daysInMonth = new Date(curYear, curMonth, 0).getDate();
        const startOffset = (firstDay.getDay() + 6) % 7;
        const todayStr = new Date().toDateString();
        const todayDate = new Date(new Date().toDateString());

        let html = Array(startOffset).fill('<div class="cal-day"></div>').join('');
        for (let day = 1; day <= daysInMonth; day++) {
            const date = new Date(curYear, curMonth - 1, day);
            const iso = `${curYear}-${String(curMonth).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
            const dow = date.getDay();
            const isWeekend = dow === 0 || dow === 6;
            const isPast = date < todayDate;
            const isAvail = available.has(iso) && !isPast;
            const isSel = selectedDate === iso;
            const isToday = date.toDateString() === todayStr;

            let css = 'cal-day';
            let attr = '';
            if (isSel)          css += ' selected';
            else if (isAvail)   { css += ' has-slots'; attr = `onclick="selectDate('${iso}',${day},event)"`; }
            else if (isWeekend) css += ' weekend blocked';
            else                css += ' blocked';
            if (isToday)        css += ' today';

            html += `<div class="${css}" ${attr}>${day}</div>`;
        }
        document.getElementById('cal-grid').innerHTML = html;
    }

    function selectDate(iso, day, e) {
        if (!selectedTreatment) return;
        selectedDate = iso; selectedTime = null;
        hideBookingSummary();
        document.querySelectorAll('.cal-day').forEach(el => el.classList.remove('selected'));
        e.target.classList.add('selected');
        loadTimeSlots(iso, day);
    }

    // ── TIME SLOTS ────────────────────────────────────────
    async function loadTimeSlots(iso, day) {
        document.getElementById('slots-title').textContent = `📅 ${MONTH_NAMES[curMonth-1]} ${day} — Available Times`;
        document.getElementById('slots-area').innerHTML = '<div class="hint">Loading…</div>';
        try {
            const res = await fetch(`http://localhost:5296/api/availability/slots?clinicId=${CLINIC_ID}&treatmentId=${selectedTreatment.id}&date=${iso}`);
            const data = await res.json();
            renderSlots(data.availableSlots ?? data);
        } catch {
            document.getElementById('slots-area').innerHTML = '<div class="hint">Could not load time slots.</div>';
        }
    }

    function renderSlots(slots) {
        if (!slots?.length) {
            document.getElementById('slots-area').innerHTML = '<div class="hint">No available times on this day.</div>';
            return;
        }
        const morning = slots.filter(s => parseInt(s) < 12);
        const afternoon = slots.filter(s => parseInt(s) >= 12);
        let html = '';
        if (morning.length) {
            html += '<div class="time-section"><h5>Morning</h5><div class="time-grid">';
            html += morning.map(s => `<div class="time-slot" onclick="selectTime('${s}',event)">${s.substring(0,5)}</div>`).join('');
            html += '</div></div>';
        }
        if (afternoon.length) {
            html += '<div class="time-section"><h5>Afternoon</h5><div class="time-grid">';
            html += afternoon.map(s => `<div class="time-slot" onclick="selectTime('${s}',event)">${s.substring(0,5)}</div>`).join('');
            html += '</div></div>';
        }
        document.getElementById('slots-area').innerHTML = html;
    }

    function selectTime(time, e) {
        selectedTime = time;
        document.querySelectorAll('.time-slot').forEach(el => el.classList.remove('selected'));
        e.target.classList.add('selected');

        const [h, m] = time.split(':').map(Number);
        const endMin = h * 60 + m + selectedTreatment.duration;
        const endTime = `${String(Math.floor(endMin/60)).padStart(2,'0')}:${String(endMin%60).padStart(2,'0')}`;

        const d = new Date(selectedDate + 'T00:00:00');
        const dateStr = d.toLocaleDateString('sv-SE', { day: 'numeric', month: 'long' });

        document.getElementById('bs-treatment').textContent = selectedTreatment.name;
        document.getElementById('bs-time').textContent = `${dateStr} · ${time.substring(0,5)}–${endTime}`;
        document.getElementById('bs-price').textContent = `${selectedTreatment.price.toLocaleString('sv-SE')} kr`;
        document.getElementById('booking-summary').style.display = 'block';
    }

    function clearSlots() {
        document.getElementById('slots-title').textContent = '📅 Select a date';
        document.getElementById('slots-area').innerHTML = '<div class="hint">← Pick a date to see available times</div>';
    }
    function hideBookingSummary() { document.getElementById('booking-summary').style.display = 'none'; }

    // ── CONFIRM ───────────────────────────────────────────
    async function confirmBooking() {
        if (!selectedTreatment || !selectedDate || !selectedTime) return;

        const btn = document.getElementById('confirm-btn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner"></span>Confirming…';

        try {
            let res;
            if (RESCHEDULE_ID) {
                res = await fetch(`http://localhost:5296/api/bookings/${RESCHEDULE_ID}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        newDate: selectedDate,
                        newStartTime: selectedTime
                    })
                });
            } else {
                res = await fetch('http://localhost:5296/api/bookings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        clinicId: CLINIC_ID,
                        patientId: parseInt(PATIENT_ID),
                        treatmentId: selectedTreatment.id,
                        date: selectedDate,
                        startTime: selectedTime
                    })
                });
            }

            if (res.ok) {
                const msg = RESCHEDULE_ID
                    ? '✅ Appointment rescheduled successfully!'
                    : '✅ Booking confirmed! A confirmation email has been sent.';
                showAlert('success', msg);
                await loadAvailableDates();
                if (selectedDate) {
                    const day = parseInt(selectedDate.split('-')[2]);
                    await loadTimeSlots(selectedDate, day);
                }
                hideBookingSummary();
                selectedTime = null;
                btn.disabled = false;
                btn.innerHTML = RESCHEDULE_ID ? 'Confirm Reschedule →' : 'Confirm Booking →';
            } else {
                const txt = await res.text();
                showAlert('error', `❌ ${RESCHEDULE_ID ? 'Reschedule' : 'Booking'} failed: ${txt}`);
                btn.disabled = false;
                btn.innerHTML = RESCHEDULE_ID ? 'Confirm Reschedule →' : 'Confirm Booking →';
            }
        } catch {
            showAlert('error', '❌ Network error. Please try again.');
            btn.disabled = false;
            btn.innerHTML = RESCHEDULE_ID ? 'Confirm Reschedule →' : 'Confirm Booking →';
        }
    }

    function showAlert(type, msg) {
        const area = document.getElementById('alert-area');
        area.innerHTML = `<div class="alert alert-${type}">${msg}</div>`;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        if (type === 'success') setTimeout(() => area.innerHTML = '', 7000);
    }

    function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    // Init
    // Init
    renderCalendar(new Set());
    loadTreatments();

    if (RESCHEDULE_ID) {
        document.querySelector('.booking-page h2').textContent = 'Reschedule Appointment';
        document.querySelector('.booking-page .subtitle').textContent = 'Choose a new date and time for your appointment.';
    }

    // ── SIGNALR ───────────────────────────────────────────
    const connection = new signalR.HubConnectionBuilder()
        .withUrl('http://localhost:5296/hubs/booking')
        .withAutomaticReconnect()
        .build();

    connection.on('SlotTaken', (data) => {
        // If the taken slot is on the date we're currently viewing, reload time slots
        if (selectedDate && data.date === selectedDate) {
            const day = parseInt(selectedDate.split('-')[2]);
            loadTimeSlots(selectedDate, day);
        }
        // Also reload available dates in case the day just became fully booked
        if (selectedTreatment) loadAvailableDates();
    });

    connection.on('SlotFreed', (data) => {
        // If a slot was freed on the date we're viewing, reload time slots
        if (selectedDate && data.date === selectedDate) {
            const day = parseInt(selectedDate.split('-')[2]);
            loadTimeSlots(selectedDate, day);
        }
        // Reload available dates in case the day became available again
        if (selectedTreatment) loadAvailableDates();
    });

    async function startSignalR() {
        try {
            await connection.start();
            await connection.invoke('JoinClinicGroup', CLINIC_ID);
        } catch (err) {
            // SignalR unavailable — booking still works, just no real-time updates
            console.warn('SignalR connection failed:', err);
        }
    }

    startSignalR();
</script>
}