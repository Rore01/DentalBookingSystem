@page
@model DentalBookingSystem.Pages.Admin.TreatmentsModel
@{
    ViewData["Title"] = "Treatments";
    Layout = "_Layout";
}

<style>
    body { background: var(--cream); }

    .admin-layout { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; }

    /* Sidebar */
    .admin-sidebar { background: var(--dark); padding: 28px 0; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
    .admin-logo { font-size: 22px; font-weight: 700; color: white; padding: 0 24px 4px; font-family: 'Playfair Display', serif; }
    .admin-role { font-size: 11px; color: rgba(255,255,255,0.35); padding: 0 24px 28px; letter-spacing: .5px; }
    .admin-nav { display: flex; flex-direction: column; gap: 2px; padding: 0 12px; }
    .admin-nav a { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; color: rgba(255,255,255,0.55); font-size: 13px; font-weight: 500; text-decoration: none; transition: all .15s; }
    .admin-nav a:hover { background: rgba(255,255,255,0.07); color: white; }
    .admin-nav a.active { background: rgba(42,168,150,0.2); color: #2aa896; }
    .nav-icon { font-size: 15px; width: 20px; text-align: center; }
    .sidebar-footer { padding: 24px; border-top: 1px solid rgba(255,255,255,0.07); margin-top: 16px; }
    .sidebar-footer a { color: rgba(255,255,255,0.4); font-size: 12px; text-decoration: none; }


    /* Main */
    .admin-main { padding: 36px 40px; }
    .admin-topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .admin-topbar h2 { font-family: 'Playfair Display', serif; font-size: 26px; color: var(--dark); }

    /* Buttons */
    .btn-primary { background: var(--teal); color: white; border: none; padding: 10px 20px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: background .15s; }
    .btn-primary:hover { background: #0f2027; }
    .btn-secondary { background: white; color: var(--dark); border: 1px solid #dde4e8; padding: 10px 16px; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .btn-danger { background: #fde8e8; color: #c0392b; border: none; padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .btn-danger:hover { background: #f5c0c0; }
    .btn-edit { background: #e8f5f0; color: #1a7a6e; border: none; padding: 7px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif; }
    .btn-edit:hover { background: #d0ede8; }

    /* Table card */
    .table-card { background: white; border-radius: 16px; border: 1px solid #e8edf0; overflow: hidden; }
    .card-header { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; border-bottom: 1px solid #e8edf0; }
    .card-header h3 { font-size: 15px; font-weight: 600; color: var(--dark); font-family: 'DM Sans', sans-serif; }
    .card-header span { font-size: 13px; color: var(--muted); }

    table { width: 100%; border-collapse: collapse; }
    thead th { padding: 12px 20px; font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .8px; background: #f8fafb; text-align: left; border-bottom: 1px solid #e8edf0; }
    tbody tr { border-bottom: 1px solid #f0f4f7; transition: background .1s; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #fafcfd; }
    tbody td { padding: 14px 20px; font-size: 13px; color: var(--dark); }
    .t-name { font-weight: 600; }
    .t-desc { color: var(--muted); font-size: 12px; margin-top: 2px; }
    .price-badge { background: #e8f5f0; color: #1a7a6e; font-weight: 700; padding: 4px 10px; border-radius: 20px; font-size: 12px; display: inline-block; }
    .duration-badge { background: #f0f4f7; color: #2c4a52; font-weight: 600; padding: 4px 10px; border-radius: 20px; font-size: 12px; display: inline-block; }
    .action-cell { display: flex; gap: 8px; }
    .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); font-size: 14px; }
    .empty-state .empty-icon { font-size: 40px; margin-bottom: 12px; }

    /* Modal */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(15,32,39,0.5); z-index: 1000; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal { background: white; border-radius: 16px; padding: 32px; width: 480px; max-width: 95vw; box-shadow: 0 20px 60px rgba(0,0,0,0.15); }
    .modal h3 { font-size: 18px; font-weight: 700; color: var(--dark); margin-bottom: 20px; font-family: 'Playfair Display', serif; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 12px; font-weight: 600; color: var(--muted); letter-spacing: .5px; margin-bottom: 6px; text-transform: uppercase; }
    .form-group input, .form-group textarea { width: 100%; padding: 10px 14px; border: 1.5px solid #dde4e8; border-radius: 8px; font-size: 14px; font-family: 'DM Sans', sans-serif; color: var(--dark); background: white; box-sizing: border-box; transition: border-color .15s; }
    .form-group input:focus, .form-group textarea:focus { outline: none; border-color: #2aa896; }
    .form-group textarea { resize: vertical; min-height: 72px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; }
    .modal-error { background: #fde8e8; border: 1px solid #f5b8b8; color: #c0392b; border-radius: 8px; padding: 10px 14px; font-size: 13px; margin-bottom: 16px; display: none; }

    /* Delete confirm */
    .delete-modal { background: white; border-radius: 16px; padding: 32px; width: 380px; max-width: 95vw; text-align: center; }
    .delete-modal .del-icon { font-size: 40px; margin-bottom: 12px; }
    .delete-modal h3 { font-size: 17px; font-weight: 700; color: var(--dark); margin-bottom: 8px; }
    .delete-modal p { font-size: 13px; color: var(--muted); margin-bottom: 24px; }
    .delete-modal .del-name { font-weight: 700; color: var(--dark); }

    .alert { padding: 12px 16px; border-radius: 10px; font-size: 13px; margin-bottom: 20px; }
    .alert-success { background: #e8f8f2; border: 1px solid #a0dfc5; color: #1a7a6e; }
    .alert-error { background: #fde8e8; border: 1px solid #f5b8b8; color: #c0392b; }

    @@media (max-width: 768px) { .admin-layout { grid-template-columns: 1fr; } .admin-sidebar { display: none; } }
</style>

<div class="admin-layout">

    <!-- SIDEBAR -->
    <div class="admin-sidebar">
        <div class="admin-logo">Denta<span style="color:#2aa896;">Care</span></div>
        <div class="admin-role">Admin Panel · Klinik @Model.ClinicId</div>
        <nav class="admin-nav">
            <a href="/Admin/Dashboard"><span class="nav-icon">📊</span> Dashboard</a>
            <a href="/Admin/Bookings"><span class="nav-icon">📅</span> Bookings</a>
            <a href="/Admin/Treatments" class="active"><span class="nav-icon">🦷</span> Treatments</a>
            <a href="/Admin/BlockedSlots"><span class="nav-icon">🚫</span> Block Times</a>
            <a href="/Admin/Patients"><span class="nav-icon">👥</span> Patients</a>
        </nav>
        <div class="sidebar-footer">
            <form asp-page="/Account/Logout" method="post">
                <button type="submit" style="background:none;border:none;cursor:pointer;padding:0;width:100%;text-align:left;">
                    <span style="color:rgba(255,255,255,0.4);font-size:12px;">🚪 Log out</span>
                </button>
            </form>
        </div>
    </div>

    <!-- MAIN -->
    <div class="admin-main">
        <div class="admin-topbar">
            <h2>🦷 Treatments</h2>
            <button class="btn-primary" onclick="openAddModal()">+ Add Treatment</button>
        </div>

        <div id="alert-area"></div>

        <div class="table-card">
            <div class="card-header">
                <h3>All Treatments</h3>
                <span id="treatment-count">Loading…</span>
            </div>
            <div id="table-area">
                <div class="empty-state"><div class="empty-icon">⏳</div>Loading treatments…</div>
            </div>
        </div>
    </div>
</div>

<!-- ADD / EDIT MODAL -->
<div class="modal-overlay" id="form-modal">
    <div class="modal">
        <h3 id="modal-title">Add Treatment</h3>
        <div class="modal-error" id="modal-error"></div>
        <div class="form-group">
            <label>Treatment Name</label>
            <input type="text" id="f-name" placeholder="e.g. Teeth Whitening" />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea id="f-desc" placeholder="Brief description of the treatment…"></textarea>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Price (kr)</label>
                <input type="number" id="f-price" placeholder="0" min="0" />
            </div>
            <div class="form-group">
                <label>Duration (minutes)</label>
                <input type="number" id="f-duration" placeholder="30" min="5" step="5" />
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-secondary" onclick="closeModal('form-modal')">Cancel</button>
            <button class="btn-primary" id="save-btn" onclick="saveTreatment()">Save Treatment</button>
        </div>
    </div>
</div>

<!-- DELETE CONFIRM MODAL -->
<div class="modal-overlay" id="delete-modal">
    <div class="delete-modal">
        <div class="del-icon">🗑️</div>
        <h3>Delete Treatment?</h3>
        <p>Are you sure you want to delete <span class="del-name" id="del-name"></span>? This cannot be undone.</p>
        <div style="display:flex;gap:10px;justify-content:center;">
            <button class="btn-secondary" onclick="closeModal('delete-modal')">Cancel</button>
            <button class="btn-danger" id="confirm-delete-btn" onclick="confirmDelete()" style="padding:10px 20px;font-size:13px;">Delete</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const CLINIC_ID = @Model.ClinicId;
    const API = 'http://localhost:5242';
    let treatments = [];
    let editingId = null;
    let deletingId = null;

    // ── LOAD ──────────────────────────────────────────────────
    async function loadTreatments() {
        try {
            const res = await fetch(`${API}/api/treatments?clinicId=${CLINIC_ID}`);
            treatments = await res.json();
            renderTable();
        } catch {
            document.getElementById('table-area').innerHTML =
                '<div class="empty-state"><div class="empty-icon">❌</div>Could not load treatments.</div>';
        }
    }

    function renderTable() {
        document.getElementById('treatment-count').textContent = `${treatments.length} treatment${treatments.length !== 1 ? 's' : ''}`;
        if (!treatments.length) {
            document.getElementById('table-area').innerHTML =
                '<div class="empty-state"><div class="empty-icon">🦷</div>No treatments yet. Add your first one!</div>';
            return;
        }
        document.getElementById('table-area').innerHTML = `
            <table>
                <thead>
                    <tr>
                        <th>Treatment</th>
                        <th>Duration</th>
                        <th>Price</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    ${treatments.map(t => `
                    <tr>
                        <td>
                            <div class="t-name">${esc(t.name)}</div>
                            ${t.description ? `<div class="t-desc">${esc(t.description)}</div>` : ''}
                        </td>
                        <td><span class="duration-badge">${t.durationMinutes} min</span></td>
                        <td><span class="price-badge">${t.price.toLocaleString('sv-SE')} kr</span></td>
                        <td>
                            <div class="action-cell">
                                <button class="btn-edit" onclick="openEditModal(${t.id})">Edit</button>
                                <button class="btn-danger" onclick="openDeleteModal(${t.id}, '${esc(t.name)}')">Delete</button>
                            </div>
                        </td>
                    </tr>`).join('')}
                </tbody>
            </table>`;
    }

    // ── ADD MODAL ─────────────────────────────────────────────
    function openAddModal() {
        editingId = null;
        document.getElementById('modal-title').textContent = 'Add Treatment';
        document.getElementById('save-btn').textContent = 'Save Treatment';
        document.getElementById('f-name').value = '';
        document.getElementById('f-desc').value = '';
        document.getElementById('f-price').value = '';
        document.getElementById('f-duration').value = '';
        document.getElementById('modal-error').style.display = 'none';
        document.getElementById('form-modal').classList.add('open');
    }

    // ── EDIT MODAL ────────────────────────────────────────────
    function openEditModal(id) {
        const t = treatments.find(x => x.id === id);
        if (!t) return;
        editingId = id;
        document.getElementById('modal-title').textContent = 'Edit Treatment';
        document.getElementById('save-btn').textContent = 'Update Treatment';
        document.getElementById('f-name').value = t.name;
        document.getElementById('f-desc').value = t.description ?? '';
        document.getElementById('f-price').value = t.price;
        document.getElementById('f-duration').value = t.durationMinutes;
        document.getElementById('modal-error').style.display = 'none';
        document.getElementById('form-modal').classList.add('open');
    }

    // ── SAVE ──────────────────────────────────────────────────
    async function saveTreatment() {
        const name = document.getElementById('f-name').value.trim();
        const desc = document.getElementById('f-desc').value.trim();
        const price = parseFloat(document.getElementById('f-price').value);
        const duration = parseInt(document.getElementById('f-duration').value);

        if (!name || isNaN(price) || isNaN(duration) || duration < 5) {
            showModalError('Please fill in all required fields correctly.');
            return;
        }

        const btn = document.getElementById('save-btn');
        btn.disabled = true;
        btn.textContent = 'Saving…';

        const body = { clinicId: CLINIC_ID, name, description: desc, price, durationMinutes: duration };

        try {
            let res;
            if (editingId) {
                res = await fetch(`${API}/api/treatments/${editingId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ...body, id: editingId })
                });
            } else {
                res = await fetch(`${API}/api/treatments`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
            }

            if (res.ok) {
                closeModal('form-modal');
                showAlert('success', editingId ? '✅ Treatment updated.' : '✅ Treatment added.');
                await loadTreatments();
            } else {
                const txt = await res.text();
                showModalError(txt || 'Something went wrong.');
            }
        } catch {
            showModalError('Network error. Please try again.');
        }

        btn.disabled = false;
        btn.textContent = editingId ? 'Update Treatment' : 'Save Treatment';
    }

    // ── DELETE ────────────────────────────────────────────────
    function openDeleteModal(id, name) {
        deletingId = id;
        document.getElementById('del-name').textContent = `"${name}"`;
        document.getElementById('delete-modal').classList.add('open');
    }

    async function confirmDelete() {
        const btn = document.getElementById('confirm-delete-btn');
        btn.disabled = true;
        btn.textContent = 'Deleting…';
        try {
            const res = await fetch(`${API}/api/treatments/${deletingId}`, { method: 'DELETE' });
            if (res.ok) {
                closeModal('delete-modal');
                showAlert('success', '✅ Treatment deleted.');
                await loadTreatments();
            } else {
                closeModal('delete-modal');
                showAlert('error', '❌ Could not delete treatment. It may have existing bookings.');
            }
        } catch {
            showAlert('error', '❌ Network error.');
        }
        btn.disabled = false;
        btn.textContent = 'Delete';
    }

    // ── HELPERS ───────────────────────────────────────────────
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    function showModalError(msg) {
        const el = document.getElementById('modal-error');
        el.textContent = msg;
        el.style.display = 'block';
    }
    function showAlert(type, msg) {
        const area = document.getElementById('alert-area');
        area.innerHTML = `<div class="alert alert-${type}">${msg}</div>`;
        if (type === 'success') setTimeout(() => area.innerHTML = '', 5000);
    }
    function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    // Close modal on overlay click
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
        overlay.addEventListener('click', e => { if (e.target === overlay) overlay.classList.remove('open'); });
    });

    loadTreatments();
</script>
}
